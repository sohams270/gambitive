---
interface Comment {
  id: string;
  name: string;
  text: string;
  date: string;
  parentId?: string;
}

interface Props {
  slug: string;
  section: string;
  comments: Comment[];
}

const { slug, section, comments } = Astro.props;

const topLevel = comments
  .filter((c) => !c.parentId)
  .sort((a, b) => a.date.localeCompare(b.date));
const repliesFor = (id: string) =>
  comments
    .filter((c) => c.parentId === id)
    .sort((a, b) => a.date.localeCompare(b.date));

const formatDate = (iso: string) =>
  new Date(iso).toLocaleDateString("en-IN", {
    day: "numeric",
    month: "short",
    year: "numeric",
  });
---

<section class="comments" id="comments" aria-label="Comments">
  <h2>Comments {comments.length > 0 && <span class="count">({comments.length})</span>}</h2>

  <p class="posted-note" role="status" hidden>
    <strong>Thanks — your comment is in.</strong> It appears here in a minute
    or two.
  </p>

  {
    topLevel.length === 0 ? (
      <p class="empty">No comments yet. Start the discussion below.</p>
    ) : (
      <ol class="thread">
        {topLevel.map((comment) => (
          <li class="comment" id={comment.id}>
            <p class="who">
              <strong>{comment.name}</strong>
              <span class="meta"> · {formatDate(comment.date)}</span>
            </p>
            <p class="text">{comment.text}</p>

            {repliesFor(comment.id).map((reply) => (
              <div class="reply" id={reply.id}>
                <p class="who">
                  <strong>{reply.name}</strong>
                  <span class="meta"> · {formatDate(reply.date)}</span>
                </p>
                <p class="text">{reply.text}</p>
              </div>
            ))}

            <details class="reply-box">
              <summary>Reply</summary>
              <form method="post" action="/api/comments" class="comment-form">
                <input type="hidden" name="slug" value={slug} />
                <input type="hidden" name="section" value={section} />
                <input type="hidden" name="parentId" value={comment.id} />
                <input type="text" name="website" class="hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
                <div class="pair">
                  <input type="text" name="name" placeholder="Name" required maxlength="60" aria-label="Name" />
                  <input type="email" name="email" placeholder="Email (never shown)" required maxlength="120" aria-label="Email" />
                </div>
                <textarea name="text" rows="3" required maxlength="4000" placeholder={`Reply to ${comment.name}…`} aria-label="Reply"></textarea>
                <button type="submit" class="btn">Post reply</button>
              </form>
            </details>
          </li>
        ))}
      </ol>
    )
  }

  <h3>Leave a comment</h3>
  <form method="post" action="/api/comments" class="comment-form main-form">
    <input type="hidden" name="slug" value={slug} />
    <input type="hidden" name="section" value={section} />
    <input type="text" name="website" class="hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
    <div class="pair">
      <input type="text" name="name" placeholder="Name" required maxlength="60" aria-label="Name" />
      <input type="email" name="email" placeholder="Email (never shown)" required maxlength="120" aria-label="Email" />
    </div>
    <textarea name="text" rows="4" required maxlength="4000" placeholder="What did we miss?" aria-label="Comment"></textarea>
    <p class="privacy">
      Your email is required but never displayed. Comments appear after a
      short delay.
    </p>
    <button type="submit" class="btn">Post comment</button>
  </form>
</section>

<script>
  // Show the "thanks" banner after a no-JS form redirect
  if (new URLSearchParams(location.search).has("commented")) {
    const note = document.querySelector<HTMLElement>(".posted-note");
    if (note) {
      note.hidden = false;
      note.scrollIntoView({ block: "center" });
    }
  }

  // Enhanced submit: post via fetch, swap the form for the response message
  document.querySelectorAll<HTMLFormElement>(".comment-form").forEach((form) => {
    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      const button = form.querySelector<HTMLButtonElement>("button[type=submit]");
      if (button) {
        button.disabled = true;
        button.textContent = "Posting…";
      }
      try {
        const res = await fetch(form.action, {
          method: "POST",
          headers: { Accept: "application/json" },
          body: new FormData(form),
        });
        const data = await res.json();
        const note = document.createElement("p");
        note.className = data.ok ? "form-note form-note--ok" : "form-note form-note--err";
        note.setAttribute("role", "status");
        note.textContent = data.message;
        if (data.ok) {
          form.replaceWith(note);
        } else {
          form.prepend(note);
          if (button) {
            button.disabled = false;
            button.textContent = form.classList.contains("main-form") ? "Post comment" : "Post reply";
          }
        }
      } catch {
        // Network hiccup: fall back to the plain form POST
        form.submit();
      }
    });
  });
</script>

<style>
  .comments {
    margin-top: var(--space-7);
    padding-top: var(--space-6);
    border-top: 1px solid var(--border);
  }
  h2 {
    font-size: var(--size-h2);
    margin-bottom: var(--space-5);
  }
  .count {
    color: var(--text-secondary);
    font-family: var(--font-sans);
    font-size: var(--size-body);
    font-weight: 400;
  }
  .empty {
    color: var(--text-secondary);
    font-size: var(--size-small);
    margin-bottom: var(--space-6);
  }
  .posted-note {
    background: var(--accent-tint);
    border: 1px solid var(--accent);
    border-radius: var(--radius);
    padding: var(--space-4) var(--space-5);
    font-size: var(--size-small);
    margin-bottom: var(--space-5);
  }
  .thread {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    margin-bottom: var(--space-7);
  }
  .who {
    font-size: var(--size-small);
  }
  .who .meta {
    color: var(--text-secondary);
    font-size: var(--size-meta);
  }
  .text {
    margin-top: var(--space-1);
    font-size: var(--size-small);
    white-space: pre-line;
  }
  .reply {
    margin-top: var(--space-4);
    margin-left: var(--space-5);
    padding-left: var(--space-4);
    border-left: 3px solid var(--accent-tint);
  }
  .reply-box {
    margin-top: var(--space-3);
  }
  .reply-box summary {
    cursor: pointer;
    color: var(--accent);
    font-size: var(--size-meta);
    font-weight: 600;
  }
  h3 {
    font-size: var(--size-h3);
    margin-bottom: var(--space-4);
  }
  .comment-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 34rem;
    margin-top: var(--space-3);
  }
  .pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
  }
  @media (max-width: 34rem) {
    .pair {
      grid-template-columns: 1fr;
    }
  }
  .comment-form input[type="text"],
  .comment-form input[type="email"],
  .comment-form textarea {
    padding: 0.625rem 0.875rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--white);
    font-size: var(--size-small);
    width: 100%;
  }
  .comment-form textarea {
    resize: vertical;
  }
  .comment-form .btn {
    align-self: flex-start;
  }
  .privacy {
    font-size: var(--size-meta);
    color: var(--text-secondary);
    margin: 0;
  }
  .hp {
    position: absolute !important;
    left: -9999px !important;
    width: 1px;
    height: 1px;
    opacity: 0;
  }
  :global(.form-note) {
    border-radius: var(--radius);
    padding: var(--space-3) var(--space-4);
    font-size: var(--size-small);
  }
  :global(.form-note--ok) {
    background: var(--accent-tint);
    border: 1px solid var(--accent);
  }
  :global(.form-note--err) {
    background: #fbeeee;
    border: 1px solid #b3564d;
  }
</style>
