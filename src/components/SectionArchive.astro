---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleCard from "./ArticleCard.astro";
import BrandMark from "./BrandMark.astro";
import { SECTIONS, type SectionSlug } from "../lib/site";

interface Props {
  section: SectionSlug;
}

const { section } = Astro.props;
const meta = SECTIONS[section];
const isHardPart = section === "the-hard-part";

const articles = (
  await getCollection(
    "articles",
    ({ data }) => data.section === section && !data.draft,
  )
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={meta.name} description={meta.tagline}>
  <div class="wrap">
    <header class="archive-header reveal">
      <div class="rule" aria-hidden="true"></div>
      <h1>
        {isHardPart && <BrandMark size={22} class="mark" />}
        {meta.name}
      </h1>
      <p class="tagline">{meta.tagline}</p>
      {
        isHardPart && (
          <p class="hard-note">
            Real numbers, real mistakes, specific decisions. Never paid
            placements — <a href="/editorial-policy/">that's policy</a>. Built
            something and learned the hard way? <a href="/the-hard-part/pitch/">Pitch your story</a>.
          </p>
        )
      }
    </header>

    {
      articles.length === 0 ? (
        <p class="empty">
          Nothing published here yet. The <a href="/newsletter/">newsletter</a>
          is where new pieces land first.
        </p>
      ) : (
        <>
          <div class="archive-grid" data-page-size="9">
            {articles.map((article) => (
              <ArticleCard article={article} showSection={false} />
            ))}
          </div>
          <div class="more-row">
            <button type="button" class="btn view-more" hidden>
              View More
            </button>
          </div>
        </>
      )
    }
  </div>
</BaseLayout>

<script>
  // Progressive reveal: 9 posts (3 rows of 3) per batch. Without JS the
  // full list stays visible, so nothing is ever unreachable.
  const grid = document.querySelector<HTMLElement>(".archive-grid");
  const button = document.querySelector<HTMLButtonElement>(".view-more");
  if (grid && button) {
    const pageSize = Number(grid.dataset.pageSize) || 9;
    const cards = Array.from(grid.children) as HTMLElement[];
    let shown = pageSize;
    const update = () => {
      cards.forEach((card, i) => card.toggleAttribute("hidden", i >= shown));
      button.hidden = shown >= cards.length;
    };
    button.addEventListener("click", () => {
      shown += pageSize;
      update();
      // Keep keyboard/screen-reader position sensible after the reveal
      cards[shown - pageSize]?.querySelector("a")?.focus();
    });
    update();
  }
</script>

<style>
  .archive-header {
    padding-block: var(--space-8) var(--space-7);
    max-width: 46rem;
  }
  .rule {
    width: 3.5rem;
    height: 6px;
    background: var(--accent);
    margin-bottom: var(--space-5);
  }
  h1 {
    font-size: var(--size-display);
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
  }
  h1 :global(.mark) {
    color: var(--accent);
    flex-shrink: 0;
  }
  .tagline {
    margin-top: var(--space-3);
    font-size: var(--size-lede);
    color: var(--text-secondary);
  }
  .hard-note {
    margin-top: var(--space-4);
    font-size: var(--size-small);
    color: var(--text-secondary);
  }
  .archive-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-7) var(--space-6);
    padding-bottom: var(--space-6);
  }
  @media (max-width: 64rem) {
    .archive-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 40rem) {
    .archive-grid {
      grid-template-columns: 1fr;
    }
  }
  /* Author styles on .card would beat the UA [hidden] rule */
  .archive-grid > :global([hidden]) {
    display: none !important;
  }
  .more-row {
    display: flex;
    justify-content: center;
    padding-bottom: var(--space-8);
  }
  /* .btn's display would beat the UA [hidden] rule, same as the cards */
  .view-more[hidden] {
    display: none !important;
  }
  .empty {
    color: var(--text-secondary);
    padding-bottom: var(--space-8);
  }
</style>
