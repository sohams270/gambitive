---
// The Gambitive mark: a minimal chess pawn — the piece a gambit spends.
// Used small: section eyebrows, quote cards, favicon, footer.
interface Props {
  size?: number;
  class?: string;
}
const { size = 10, class: className } = Astro.props;
---

<svg
  class={className}
  width={size}
  height={size * 1.3}
  viewBox="0 0 12 16"
  fill="currentColor"
  aria-hidden="true"
>
  <circle cx="6" cy="3.2" r="2.7"></circle>
  <path d="M4.3 5.6h3.4l1.2 6.4H3.1L4.3 5.6Z"></path>
  <rect x="2" y="13" width="8" height="2.4" rx="0.7"></rect>
</svg>
