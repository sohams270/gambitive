---
import { SECTIONS } from "../../lib/site";

interface Props {
  values?: {
    title?: string;
    dek?: string;
    section?: string;
    author?: string;
    pubDate?: string;
    tldr?: string;
    authorBio?: string;
    image?: string;
    imageAlt?: string;
    featured?: boolean;
    draft?: boolean;
    body?: string;
  };
  submitLabel: string;
}

const { values = {}, submitLabel } = Astro.props;
const today = new Date().toISOString().slice(0, 10);
const user = Astro.locals.user;
---

<form method="post" class="admin-form" enctype="multipart/form-data">
  <div class="field">
    <label for="title">Headline</label>
    <input id="title" name="title" type="text" required value={values.title ?? ""} />
  </div>

  <div class="field">
    <label for="dek">Dek</label>
    <p class="hint">One-line summary shown on cards, search results, and social.</p>
    <input id="dek" name="dek" type="text" required value={values.dek ?? ""} />
  </div>

  <div class="row">
    <div class="field">
      <label for="section">Section</label>
      <select id="section" name="section" required>
        {
          Object.values(SECTIONS).map((s) => (
            <option value={s.slug} selected={values.section === s.slug}>
              {s.name}
            </option>
          ))
        }
      </select>
    </div>
    <div class="field">
      <label for="pubDate">Publish date</label>
      <input id="pubDate" name="pubDate" type="date" required value={values.pubDate ?? today} />
    </div>
  </div>

  <div class="field">
    <label for="author">Byline</label>
    <input id="author" name="author" type="text" required value={values.author ?? user?.name ?? ""} />
  </div>

  <div class="field">
    <label for="tldr">TL;DR <span class="hint" style="display:inline">(optional)</span></label>
    <p class="hint">One point per line. Shown in the article's left rail.</p>
    <textarea id="tldr" name="tldr" rows="4">{values.tldr ?? ""}</textarea>
  </div>

  <div class="field">
    <label for="image">Feature image {values.image && <span class="hint" style="display:inline">(currently: {values.image})</span>}</label>
    <p class="hint">1200×630 works best. SVG, PNG, JPG, or WebP, up to 3 MB. Leave empty to keep the current image.</p>
    <input id="image" name="image" type="file" accept=".svg,.png,.jpg,.jpeg,.webp" />
  </div>

  <div class="field">
    <label for="imageAlt">Image alt text</label>
    <input id="imageAlt" name="imageAlt" type="text" value={values.imageAlt ?? ""} />
  </div>

  <div class="field">
    <label for="authorBio">Author bio <span class="hint" style="display:inline">(optional — house bio used otherwise)</span></label>
    <input id="authorBio" name="authorBio" type="text" value={values.authorBio ?? ""} />
  </div>

  <div class="field">
    <label for="body">Body (Markdown)</label>
    <p class="hint">
      Standard Markdown. Pull-quote card:
      &lt;figure class="quote-card"&gt;&lt;blockquote&gt;Quote.&lt;/blockquote&gt;&lt;figcaption&gt;Name, Company&lt;/figcaption&gt;&lt;/figure&gt;
    </p>
    <textarea id="body" name="body" rows="22" required>{values.body ?? ""}</textarea>
  </div>

  <div class="checks">
    <label><input type="checkbox" name="featured" checked={values.featured} /> Featured (homepage lead)</label>
    <label><input type="checkbox" name="draft" checked={values.draft} /> Draft (hidden from site)</label>
  </div>

  <div>
    <button type="submit" class="btn" name="intent" value="save">{submitLabel}</button>
  </div>
</form>
