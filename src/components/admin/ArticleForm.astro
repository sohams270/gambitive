---
import { SECTIONS } from "../../lib/site";

interface Props {
  values?: {
    title?: string;
    dek?: string;
    section?: string;
    author?: string;
    pubDate?: string;
    tldr?: string;
    authorBio?: string;
    image?: string;
    imageAlt?: string;
    featured?: boolean;
    draft?: boolean;
    body?: string;
  };
  submitLabel: string;
}

const { values = {}, submitLabel } = Astro.props;
const today = new Date().toISOString().slice(0, 10);
const user = Astro.locals.user;
---

<form method="post" class="admin-form" enctype="multipart/form-data">
  <div class="field">
    <label for="title">Headline</label>
    <input id="title" name="title" type="text" required value={values.title ?? ""} />
  </div>

  <div class="field">
    <label for="dek">Dek</label>
    <p class="hint">One-line summary shown on cards, search results, and social.</p>
    <input id="dek" name="dek" type="text" required value={values.dek ?? ""} />
  </div>

  <div class="row">
    <div class="field">
      <label for="section">Section</label>
      <select id="section" name="section" required>
        {
          Object.values(SECTIONS).map((s) => (
            <option value={s.slug} selected={values.section === s.slug}>
              {s.name}
            </option>
          ))
        }
      </select>
    </div>
    <div class="field">
      <label for="pubDate">Publish date</label>
      <input id="pubDate" name="pubDate" type="date" required value={values.pubDate ?? today} />
    </div>
  </div>

  <div class="field">
    <label for="author">Byline</label>
    <input id="author" name="author" type="text" required value={values.author ?? user?.name ?? ""} />
  </div>

  <div class="field">
    <label for="tldr">TL;DR <span class="hint" style="display:inline">(optional)</span></label>
    <p class="hint">One point per line. Shown in the article's left rail.</p>
    <textarea id="tldr" name="tldr" rows="4">{values.tldr ?? ""}</textarea>
  </div>

  <div class="field">
    <label for="image">Feature image {values.image && <span class="hint" style="display:inline">(currently: {values.image})</span>}</label>
    <p class="hint">1200×630 works best. SVG, PNG, JPG, or WebP, up to 3 MB. Leave empty to keep the current image.</p>
    <input id="image" name="image" type="file" accept=".svg,.png,.jpg,.jpeg,.webp" />
  </div>

  <div class="field">
    <label for="imageAlt">Image alt text</label>
    <input id="imageAlt" name="imageAlt" type="text" value={values.imageAlt ?? ""} />
  </div>

  <div class="field">
    <label for="authorBio">Author bio <span class="hint" style="display:inline">(optional — house bio used otherwise)</span></label>
    <input id="authorBio" name="authorBio" type="text" value={values.authorBio ?? ""} />
  </div>

  <div class="field">
    <label for="body">Body</label>
    <p class="hint">
      Use the toolbar to format — it writes clean Markdown underneath. The
      "❝" button inserts the Gambitive pull-quote card. Eye icon previews,
      arrows go fullscreen.
    </p>
    <textarea id="body" name="body" rows="22" required>{values.body ?? ""}</textarea>
  </div>

  <div class="checks">
    <label><input type="checkbox" name="featured" checked={values.featured} /> Featured (homepage lead)</label>
    <label><input type="checkbox" name="draft" checked={values.draft} /> Draft (hidden from site)</label>
  </div>

  <div>
    <button type="submit" class="btn" name="intent" value="save">{submitLabel}</button>
  </div>
</form>

<script>
  import EasyMDE from "easymde";
  import "easymde/dist/easymde.min.css";
  import "@fortawesome/fontawesome-free/css/all.min.css";

  const textarea = document.getElementById("body") as HTMLTextAreaElement | null;
  if (textarea) {
    // The editor takes over rendering; drop `required` so the hidden
    // textarea can't block submission from an unfocusable state.
    textarea.required = false;

    const editor = new EasyMDE({
      element: textarea,
      autoDownloadFontAwesome: false,
      spellChecker: false,
      status: ["lines", "words"],
      minHeight: "420px",
      toolbar: [
        "bold",
        "italic",
        "strikethrough",
        "heading-2",
        "heading-3",
        "|",
        "quote",
        {
          name: "quote-card",
          action: (mde) => {
            const cm = mde.codemirror;
            cm.replaceSelection(
              '\n<figure class="quote-card">\n  <blockquote>The quote.</blockquote>\n  <figcaption>Name, Company</figcaption>\n</figure>\n',
            );
            cm.focus();
          },
          className: "fa fa-quote-right",
          title: "Insert Gambitive quote card",
        },
        "unordered-list",
        "ordered-list",
        "table",
        "horizontal-rule",
        "|",
        "link",
        "image",
        "code",
        "|",
        "preview",
        "side-by-side",
        "fullscreen",
        "|",
        "guide",
      ],
    });

    // Guarantee the textarea carries the editor content on submit.
    textarea.closest("form")?.addEventListener("submit", (event) => {
      const value = editor.value().trim();
      textarea.value = value;
      if (!value) {
        event.preventDefault();
        alert("The body is empty.");
      }
    });
  }
</script>

<style is:global>
  /* Blend EasyMDE into the admin design system */
  .EasyMDEContainer .editor-toolbar {
    border-color: var(--border);
    border-radius: var(--radius) var(--radius) 0 0;
    background: var(--bg-muted);
  }
  .EasyMDEContainer .CodeMirror {
    border-color: var(--border);
    border-radius: 0 0 var(--radius) var(--radius);
    font-size: var(--size-small);
    line-height: 1.6;
  }
  .EasyMDEContainer .editor-toolbar button.active,
  .EasyMDEContainer .editor-toolbar button:hover {
    background: var(--accent-tint);
    border-color: var(--accent);
  }
  .EasyMDEContainer .editor-statusbar {
    color: var(--text-secondary);
  }
</style>
